# Pooled connection for the app (Neon: use the *-pooler* host; pgbouncer=true required for Prisma)
DATABASE_URL=postgresql://user:password@ep-example-pooler.us-east-2.aws.neon.tech/signets?sslmode=require&pgbouncer=true

# Direct connection for Prisma migrations (Neon: non-pooler host)
# For local Postgres you can set this to the same value as DATABASE_URL.
DIRECT_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/signets?sslmode=require

BETTER_AUTH_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
PORT=3001

# Comma-separated browser origins allowed to call the API (web app, extension redirect)
WEB_ORIGIN=http://localhost:3000
