generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ShotKind {
  photo
  video
  animated_gif
}

model User {
  id                   String    @id @default(uuid()) @db.Uuid
  slug                 String    @unique
  createdAt            DateTime  @default(now()) @db.Timestamptz(6)
  lastBookmarkSyncAt   DateTime? @db.Timestamptz(6)
  shots                Shot[]
}

model Shot {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  postId           String
  mediaId          String
  kind             ShotKind
  mediaUrl         String
  mediaPosterUrl   String?
  hostedImageKey   String?
  width            Int?
  height           Int?
  authorHandle     String
  authorName       String?
  caption          String?
  bookmarkedAt     DateTime @db.Timestamptz(6)
  isFavorite       Boolean  @default(false)
  createdAt        DateTime @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @db.Timestamptz(6)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
  @@index([userId, bookmarkedAt])
  @@index([userId, authorHandle])
}
