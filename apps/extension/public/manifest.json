{
  "manifest_version": 3,
  "name": "Signets Sync",
  "description": "Sync X bookmarks into Signets",
  "version": "0.1.0",
  "permissions": [
    "identity",
    "storage",
    "scripting",
    "activeTab",
    "tabs",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "popup.html"
  },
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "http://localhost:3001/*",
    "https://signets-api.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/i/bookmarks*",
        "https://twitter.com/i/bookmarks*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Open Signets Sync side panel"
  }
}
